SUPABASE_PROJECT_REF=kirctxhxcmnncpuxjknw
SUPABASE_URL=https://kirctxhxcmnncpuxjknw.supabase.co
SUPABASE_ANON_KEY=replace-with-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Use the Supabase pooler URL for app traffic. Keep the direct URL for one-off admin work if needed.
DATABASE_URL=postgresql://postgres.kirctxhxcmnncpuxjknw:replace-password@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres
SUPABASE_POOLER_DATABASE_URL=${DATABASE_URL}
SUPABASE_DIRECT_DATABASE_URL=postgresql://postgres:replace-password@db.kirctxhxcmnncpuxjknw.supabase.co:5432/postgres
DATABASE_CONN_MAX_AGE=0

NETRA_DATABASE_PROVIDER=supabase
NETRA_DATABASE_MODE=supabase
NETRA_STORAGE_PROVIDER=supabase
NETRA_QUEUE_PROVIDER=supabase-pgmq
NETRA_REALTIME_PROVIDER=supabase
NETRA_AUTH_PROVIDER=supabase
NETRA_SEARCH_PROVIDER=postgres
NETRA_PROCESSING_MODE=hybrid
NETRA_SYNC_FALLBACK_ENABLED=1
NETRA_SUPABASE_START_WORKERS=0

NETRA_EVIDENCE_ENCRYPTION=on
NETRA_EVIDENCE_KEY=replace-with-at-least-32-random-characters
NETRA_EVIDENCE_KEY_ID=supabase-dev-key-001
NETRA_SENSOR_SHARED_KEY=replace-with-local-sensor-shared-key
NETRA_WEBHOOK_SIGNING_SECRET=replace-with-webhook-secret
NETRA_MAX_UPLOAD_MB=1024

DJANGO_DEBUG=1
DJANGO_SECRET_KEY=replace-with-django-secret
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

VITE_SUPABASE_URL=https://kirctxhxcmnncpuxjknw.supabase.co
VITE_SUPABASE_ANON_KEY=replace-with-anon-key
VITE_SUPABASE_REALTIME_ENABLED=1

# Optional validator credentials for npm run netra:validate:supabase.
# Create this user manually in Supabase Auth; do not enable public signup.
SUPABASE_TEST_EMAIL=
SUPABASE_TEST_PASSWORD=
