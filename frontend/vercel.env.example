# Public, build-time Vite variables for the new Vercel frontend project.
# VITE_SUPABASE_ANON_KEY is a browser publishable/anon key, never a service-role key.
VITE_API_BASE_URL=https://replace-with-new-railway-domain.up.railway.app/api
VITE_SUPABASE_URL=https://replace-with-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=replace-with-current-publishable-or-anon-key
VITE_SUPABASE_REALTIME_ENABLED=0
VITE_DEPLOYMENT_PROFILE=hackathon-core
VITE_MAX_UPLOAD_MB=50
VITE_DIRECT_UPLOAD_ENABLED=0
VITE_BPF_FILTER_ENABLED=1
VITE_CYBER_VIDEO_URL=
VITE_CONTACT_EMAIL=
VITE_GITHUB_URL=https://github.com/krishna0605/Netra
VITE_LINKEDIN_URL=
