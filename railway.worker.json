{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "backend/Dockerfile.worker",
    "watchPatterns": [
      "backend/**",
      "ml-services/anomaly-engine/**",
      "railway.worker.json"
    ]
  },
  "deploy": {
    "startCommand": "python manage.py run_postgres_worker",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "overlapSeconds": 20,
    "drainingSeconds": 20
  }
}
