flowchart TB
  P["Packets + sessions + Zeek records"] --> F["Feature extraction"]
  F --> F1["Endpoint and service features"]
  F --> F2["DNS length and repetition"]
  F --> F3["Timing and beacon regularity"]
  F --> F4["Volume and fan-out"]
  F1 --> RULES["Deterministic rules"]
  F2 --> RULES
  F3 --> MODEL["Random Forest prototype"]
  F4 --> MODEL
  RULES --> MERGE["Evidence-aware finding synthesis"]
  MODEL --> MERGE
  MERGE --> EX["Explanation + confidence + evidence IDs"]
  EX --> HUMAN["Human investigator review"]
  HUMAN --> DECISION{"Disposition"}
  DECISION -->|Confirm| CASE["Link to case/report"]
  DECISION -->|Reject| TUNE["Record feedback / tune threshold"]
  DECISION -->|Needs context| CORR["Correlate endpoint or server logs"]

