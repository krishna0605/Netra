flowchart TB
  A["Authorized acquisition / import"] --> B["Validate capture structure"]
  B --> C["Plaintext SHA-256 evidence identity"]
  C --> D["Encrypt artifact"]
  D --> E["Private storage object + encrypted hash"]
  E --> F["Evidence manifest"]
  F --> G["Analysis event"]
  G --> H["Report / export event"]
  H --> I["Download / access event"]
  I --> J["Integrity re-verification"]

  C -. anchors .-> L["Hash-linked custody ledger"]
  F -. appends .-> L
  G -. appends .-> L
  H -. appends .-> L
  I -. appends .-> L
  J -. verifies .-> L

  T1["Control: backend-only service credentials"] --> E
  T2["Control: authenticated and logged actions"] --> I
  T3["Control: key rotation and retention policy"] --> E
  T4["Boundary: legal admissibility requires authority review"] --> J

  classDef process fill:#EAF1F6,stroke:#2D5F88,color:#17202A;
  classDef ledger fill:#E9F5EE,stroke:#3E7C59,color:#214A35,stroke-width:2px;
  classDef control fill:#FFF7E8,stroke:#B7791F,color:#5A3A00;
  class A,B,C,D,E,F,G,H,I,J process;
  class L ledger;
  class T1,T2,T3,T4 control;

