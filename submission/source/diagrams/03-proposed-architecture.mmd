flowchart TB
  U["Authorized investigator"] --> UI["React investigation console"]
  UI --> API["Django API / trusted processing boundary"]

  subgraph COMPUTE["Evidence processing"]
    API --> V["Validation + normalization"]
    V --> H["SHA-256 + encryption"]
    H --> T["TShark packet extraction"]
    H --> Z["Zeek offline analysis"]
    T --> S["Sessions + protocol features"]
    Z --> S
    S --> R["Rules + anomaly scoring"]
    R --> P["Persistence + artifact generation"]
  end

  subgraph DATA["Managed data plane"]
    DB["PostgreSQL case records"]
    ST["Private object storage"]
    Q["PGMQ queues"]
    RT["Realtime operational events"]
  end

  P --> DB
  H --> ST
  P --> ST
  API <--> Q
  API <--> RT
  DB --> API
  ST --> API
  API --> UI

