{
  "name": "netra-platform",
  "private": true,
  "scripts": {
    "netra": "npm run netra:start",
    "netra:start": "powershell -ExecutionPolicy Bypass -File ./infra/scripts/start-netra-production.ps1",
    "netra:start:production": "powershell -ExecutionPolicy Bypass -File ./infra/scripts/start-netra-production.ps1",
    "netra:stop": "powershell -ExecutionPolicy Bypass -File ./infra/scripts/stop-netra.ps1",
    "netra:validate": "powershell -ExecutionPolicy Bypass -File ./infra/scripts/validate-production-phase11.ps1",
    "netra:validate:production": "powershell -ExecutionPolicy Bypass -File ./infra/scripts/validate-production-phase11.ps1",
    "netra:sensor:install": "powershell -ExecutionPolicy Bypass -File ./sensor-agent/scripts/install-windows.ps1",
    "netra:sensor:check": "powershell -ExecutionPolicy Bypass -File ./sensor-agent/scripts/run-windows.ps1 check",
    "netra:sensor:interfaces": "powershell -ExecutionPolicy Bypass -File ./sensor-agent/scripts/run-windows.ps1 interfaces",
    "netra:sensor:start": "powershell -ExecutionPolicy Bypass -File ./sensor-agent/scripts/run-windows.ps1 run"
  }
}
