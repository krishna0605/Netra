# Private runtime variables for the new Railway NETRA API/analysis service.
# Never place this file's real values in Vercel or source control.
DJANGO_DEBUG=0
DJANGO_SECRET_KEY=replace-with-strong-random-django-secret
DJANGO_ALLOWED_HOSTS=.up.railway.app,healthcheck.railway.app,localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://replace-with-new-vercel-domain.vercel.app
DJANGO_SECURE_PROXY_SSL_HEADER=1
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=0
DJANGO_SECURE_HSTS_PRELOAD=0

DATABASE_URL=postgresql://replace-with-supabase-session-pooler-url
DATABASE_CONN_MAX_AGE=0
SUPABASE_PROJECT_REF=replace-with-project-ref
SUPABASE_URL=https://replace-with-project-ref.supabase.co
SUPABASE_ANON_KEY=replace-with-current-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-current-backend-only-service-role-key

NETRA_DEPLOYMENT_PROFILE=hackathon-core
NETRA_DEPLOYMENT_ENV=production
NETRA_RELEASE_ID=replace-with-release-id
NETRA_PUBLIC_BASE_URL=https://replace-with-new-vercel-domain.vercel.app
NETRA_FRONTEND_ORIGINS=https://replace-with-new-vercel-domain.vercel.app
NETRA_REQUIRE_HTTPS=1
NETRA_ACCESS_MODE=bearer
NETRA_PUBLIC_API_AUTH_REQUIRED=1
NETRA_DEV_ROLE_HEADERS=0
NETRA_AUTH_PROXY_ENABLED=0

NETRA_DATABASE_PROVIDER=supabase
NETRA_DATABASE_MODE=supabase
NETRA_STORAGE_PROVIDER=supabase
NETRA_QUEUE_PROVIDER=postgres-row-lock
NETRA_REALTIME_PROVIDER=supabase
NETRA_AUTH_PROVIDER=supabase
NETRA_SEARCH_PROVIDER=postgres
NETRA_PROCESSING_MODE=postgres-worker
NETRA_SYNC_FALLBACK_ENABLED=1
NETRA_SUPABASE_START_WORKERS=0
NETRA_ENABLE_LAB_TOOLS=0
NETRA_ENABLE_HOST_CAPTURE=0
NETRA_MAX_UPLOAD_MB=50
NETRA_BPF_FILTER_ENABLED=0
NETRA_WORKER_MAX_RETRIES=3
NETRA_JOB_LEASE_SECONDS=900
NETRA_JOB_POLL_SECONDS=2

NETRA_EVIDENCE_ENCRYPTION=on
NETRA_EVIDENCE_KEY=replace-with-32-plus-random-characters
NETRA_EVIDENCE_KEY_ID=hackathon-key-001
NETRA_EVIDENCE_PREVIOUS_KEYS=
NETRA_SENSOR_SHARED_KEY=replace-with-random-sensor-key
NETRA_WEBHOOK_SIGNING_SECRET=replace-with-random-webhook-secret

GUNICORN_WORKERS=2
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=240
